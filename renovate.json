{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "kubernetes": {
    "managerFilePatterns": [
      "/clusters/.*/.*\\.yaml$/"
    ]
  },
  "flux": {
    "managerFilePatterns": [
      "/clusters/.*/.*\\.yaml$/"
    ]
  },
  "customManagers": [
    {
      "description": "Track versions pinned via '# renovate: datasource=... depName=...' comments (e.g. KubeVirt/CDI/Multus release-asset URLs)",
      "customType": "regex",
      "managerFilePatterns": [
        "/clusters/.*\\.ya?ml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?\\s+[\\s\\S]*?(?<currentValue>v?\\d+\\.\\d+\\.\\d+(?:-\\w+)?)"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    }
  ],
  "packageRules": [
    {
      "description": "Lock MySQL to v8",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["mysql"],
      "allowedVersions": "^8"
    },
    {
      "description": "Lock meilisearch to v1.12.8",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["getmeili/meilisearch"],
      "allowedVersions": "v1.12.x"
    },
    {
      "description": "Lock stalwart to v0.16.x: 0.x majors are breaking, migrate deliberately (see v0_16.md)",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["stalwartlabs/stalwart"],
      "allowedVersions": "v0.16.x"
    },
    {
      "description": "Disable updates for gateway-api",
      "matchDatasources": ["github-tags"],
      "matchPackageNames": ["kubernetes-sigs/gateway-api"],
      "enabled": false
    },
    {
      "description": "Extract version for termix (remove release- prefix)",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/lukegus/termix"],
      "versioning": "regex:^release-(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$"
    },
    {
      "description": "Parse version for roundcubemail (keep apache-nonroot)",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["roundcube/roundcubemail"],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-apache-nonroot$"
    },
    {
      "description": "Parse version for apache tika (keep -full)",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["apache/tika"],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)\\.(?<build>\\d+)-full$"
    },
    {
      "description": "Parse version for vectorchord (keep PG17)",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/tensorchord/cloudnative-vectorchord"],
      "versioning": "regex:^17-(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$"
    },
    {
      "description": "Parse version for gitea runner (keep -dind suffix)",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["gitea/runner"],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-dind$"
    }
  ]
}
